{
    "info": {
        "_postman_id": "bds-api-collection",
        "name": "BDS App API (v1)",
        "description": "API Documentation.\n\nRequired Headers:\n- X-API-KEY: {{apiKey}}\n- Authorization: Bearer {{token}}",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.access_token) {",
                                    "    pm.environment.set(\"token\", jsonData.access_token);",
                                    "    console.log(\"Token updated\");",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\",\n    \"device_name\": \"Postman\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "login"]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Profile",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": "{{baseUrl}}/me"
                    }
                }
            ]
        },
        {
            "name": "Properties",
            "item": [
                {
                    "name": "List Properties",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": "{{baseUrl}}/properties"
                    }
                }
            ]
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "pm.request.headers.add({",
                    "    key: 'X-API-KEY',",
                    "    value: pm.environment.get('apiKey') || 'my-secret-ios-key'",
                    "});",
                    "pm.request.headers.add({",
                    "    key: 'Accept',",
                    "    value: 'application/json'",
                    "});"
                ]
            }
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000/api/v1",
            "type": "string"
        },
        {
            "key": "apiKey",
            "value": "my-secret-ios-key",
            "type": "string"
        }
    ]
}

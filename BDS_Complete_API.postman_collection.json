{
    "info": {
        "_postman_id": "bds-complete-api-collection",
        "name": "API Quản Lý Bất Động Sản",
        "description": "Tài liệu API cho Hệ Thống Quản Lý Bất Động Sản.\n\nXác thực 2 lớp:\n1. App-level: Header X-API-KEY (bắt buộc cho MỌI request)\n2. User-level: Bearer Token (sau khi đăng nhập)\n\nBase URL: {{baseUrl}}\nMôi trường: Development/Production",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Xác Thực & Bảo Mật",
            "description": "Các API liên quan đến đăng nhập, đăng xuất, quên mật khẩu, đổi mật khẩu",
            "item": [
                {
                    "name": "Đăng Nhập",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.access_token) {",
                                    "    pm.environment.set('token', jsonData.access_token);",
                                    "    pm.environment.set('refresh_token', jsonData.refresh_token);",
                                    "    console.log('✅ Token đã lưu thành công');",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-KEY",
                                "value": "{{apiKey}}",
                                "type": "text",
                                "description": "API Key của ứng dụng"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\",\n    \"device_name\": \"Mobile App\",\n    \"remember\": true\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "login"]
                        },
                        "description": "Đăng nhập và nhận access_token + refresh_token"
                    }
                },
                {
                    "name": "Làm Mới Token",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{refresh_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-KEY",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/refresh",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "refresh"]
                        },
                        "description": "Dùng refresh_token để lấy access_token mới"
                    }
                },
                {
                    "name": "Đăng Xuất",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-KEY",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/logout",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "logout"]
                        },
                        "description": "Đăng xuất và hủy token hiện tại"
                    }
                },
                {
                    "name": "Bước 1 - Quên Mật Khẩu (Gửi OTP)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.otp) {",
                                    "    pm.environment.set('otp', jsonData.otp);",
                                    "    console.log('OTP: ' + jsonData.otp);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-KEY",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@example.com\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/forgot-password",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "forgot-password"]
                        },
                        "description": "Gửi mã OTP về email. Trong môi trường dev, OTP sẽ hiện trong response."
                    }
                },
                {
                    "name": "Bước 2 - Xác Thực OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-KEY",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@example.com\",\n    \"otp\": \"{{otp}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/verify-otp",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "verify-otp"]
                        },
                        "description": "Xác thực mã OTP. Nếu đúng sẽ nhận được reset_token."
                    }
                },
                {
                    "name": "Bước 3 - Đặt Lại Mật Khẩu",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-KEY",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@example.com\",\n    \"otp\": \"{{otp}}\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/reset-password",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "reset-password"]
                        },
                        "description": "Đặt lại mật khẩu mới. Cần email và OTP hợp lệ."
                    }
                },
                {
                    "name": "Đổi Mật Khẩu",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-KEY",
                                "value": "{{apiKey}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"current_password\": \"password\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/change-password",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "change-password"]
                        },
                        "description": "Đổi mật khẩu khi đã đăng nhập (cần mật khẩu cũ)"
                    }
                }
            ]
        },

        {
            "name": "🔐 Authentication",
            "description": "## Authentication APIs\n\nQuản lý login, logout, forgot password, token refresh.\n\n### Token Lifecycle\n- access_token: 1 giờ\n- refresh_token: 30 ngày",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-KEY",
                                "value": "{{apiKey}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": {
                                "1": "auth",
                                "2": "login"
                            }
                        },
                        "description": "## Login\n\nĐăng nhập vào hệ thống.\n\n### Request\n| Field | Type | Required |\n|-------|------|----------|\n| email | string | ✅ |\n| password | string | ✅ |\n| device_name | string | ❌ |\n\n### Response\nTraả về `access_token` và `refresh_token`",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\",\n    \"device_name\": \"Postman\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var json = pm.response.json();",
                                    "if (json.access_token) {",
                                    "  pm.environment.set('token', json.access_token);",
                                    "  pm.environment.set('refresh_token', json.refresh_token);",
                                    "  console.log('✅ Token saved');",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ]
                },

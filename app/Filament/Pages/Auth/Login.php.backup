<?php

declare(strict_types=1);

namespace App\Filament\Pages\Auth;

use Filament\Forms\Components\Checkbox;
use Filament\Forms\Components\Component;
use Filament\Forms\Components\TextInput;
use Filament\Forms\Form;
use Filament\Notifications\Notification;
use Filament\Pages\Auth\Login as BaseLogin;
use Illuminate\Validation\ValidationException;

class Login extends BaseLogin
{
    /**
     * Custom form với validation rõ ràng
     */
    public function form(Form $form): Form
    {
        return $form
            ->schema([
                $this->getEmailFormComponent()
                    ->validationMessages([
                        'required' => 'Vui lòng nhập địa chỉ email.',
                        'email' => 'Địa chỉ email không hợp lệ.',
                    ]),
                $this->getPasswordFormComponent()
                    ->validationMessages([
                        'required' => 'Vui lòng nhập mật khẩu.',
                    ]),
                $this->getRememberFormComponent(),
            ]);
    }

    /**
     * Email field
     */
    protected function getEmailFormComponent(): Component
    {
        return TextInput::make('email')
            ->label('Email')
            ->email()
            ->required()
            ->autocomplete()
            ->autofocus()
            ->extraInputAttributes(['tabindex' => 1])
            ->placeholder('admin@example.com');
    }

    /**
     * Password field
     */
    protected function getPasswordFormComponent(): Component
    {
        return TextInput::make('password')
            ->label('Mật khẩu')
            ->password()
            ->revealable()
            ->required()
            ->extraInputAttributes(['tabindex' => 2])
            ->placeholder('Nhập mật khẩu của bạn');
    }

    /**
     * Remember me checkbox
     */
    protected function getRememberFormComponent(): Component
    {
        return Checkbox::make('remember')
            ->label('Ghi nhớ đăng nhập')
            ->extraAttributes(['tabindex' => 3]);
    }

    /**
     * Override authenticate để thêm notifications
     */
    protected function throwFailureValidationException(): never
    {
        // Show error notification
        Notification::make()
            ->danger()
            ->title('Đăng nhập thất bại!')
            ->body('Email hoặc mật khẩu không chính xác. Vui lòng thử lại.')
            ->persistent()
            ->send();

        throw ValidationException::withMessages([
            'data.email' => 'Thông tin đăng nhập không chính xác.',
        ]);
    }

    /**
     * Customize heading
     */
    public function getHeading(): string
    {
        return 'Đăng nhập vào hệ thống';
    }

    /**
     * Add custom view rendering for success notification
     */
    public function mount(): void
    {
        // MUST call parent first to initialize Livewire form
        parent::mount();

        // Check if just logged out
        if (session('status') === 'logged-out') {
            Notification::make()
                ->success()
                ->title('Đăng xuất thành công')
                ->body('Bạn đã đăng xuất khỏi hệ thống.')
                ->send();
        }

        // Check if redirected from fallback route (Livewire failure)
        if (session('error')) {
            Notification::make()
                ->warning()
                ->title('Lỗi đăng nhập')
                ->body(session('error'))
                ->persistent()
                ->send();
        }
    }
}

# Security rules for BDS project commands

# Chặn các lệnh nguy hiểm hoặc yêu cầu xác nhận
prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Không được phép sử dụng rm -rf để tránh mất dữ liệu nghiêm trọng."
)

prefix_rule(
    pattern = ["php", "artisan", "migrate:fresh"],
    decision = "prompt",
    justification = "Lệnh này sẽ xóa sạch database. Bạn có chắc chắn muốn thực hiện không?"
)

prefix_rule(
    pattern = ["php", "artisan", "db:seed"],
    decision = "prompt",
    justification = "Gieo dữ liệu mẫu có thể thay đổi trạng thái hiện tại của DB."
)

# Cho phép các lệnh an toàn
prefix_rule(
    pattern = ["php", "artisan", "make:"],
    decision = "allow"
)

prefix_rule(
    pattern = ["composer", "install"],
    decision = "allow"
)
